<%- include('partials/head') %>
  </head>

  <body class="flex flex-wrap flex-col items-center">
    <%- include('partials/header') %>
      <header>
        <h1 class="text-black text-4xl p-4 font-medium shadow-lg rounded-lg mt-10">Register your Home on Airbnb</h1>
      </header>

      <main class="mt-10 p-6 rounded-lg shadow-lg w-full md:w-[75%] bg-white">
        <form action="/add-home" method="POST">
          <input class="border border-gray-300 rounded-sm py-2 px-4 mb-4 w-full focus:outline-none focus:border-sky-500" type="text" id="houseName" name="houseName" placeholder="Enter Your House Name"><br>
          <input class="border border-gray-300 rounded-sm py-2 px-4 mb-4 w-full focus:outline-none focus:border-sky-500" type="text" id="price" name="price" placeholder="Price Per Night"><br>
          <input class="border border-gray-300 rounded-sm py-2 px-4 mb-4 w-full focus:outline-none focus:border-sky-500" type="text" id="locationName" name="locationName" placeholder="Location"><br>
          <input class="border border-gray-300 rounded-sm py-2 px-4 mb-4 w-full focus:outline-none focus:border-sky-500" type="text" id="rating" name="rating" placeholder="Rating"><br>
          <input class="border border-gray-300 rounded-sm py-2 px-4 mb-4 w-full focus:outline-none focus:border-sky-500" type="text" id="photo" name="photo" placeholder="Photo URL"><br>
          <input class="text-white font-medium bg-sky-500 py-2 px-4 w-full rounded-sm hover:bg-sky-600" type="submit" value="Submit">
        </form>
      </main>

      <a href="/"
        class="text-base font-medium text-blue-500 no-underline p-2 border border-slate-500 shadow-md shadow-sky-300 rounded-md my-5 hover:shadow-lg">Go
        back to Home</a>

  </body>

  </html>