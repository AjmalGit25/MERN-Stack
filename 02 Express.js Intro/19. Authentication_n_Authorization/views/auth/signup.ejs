<%- include('../partials/head') %>

  <body class="bg-blue-500">
    <%- include('../partials/header') %>
      <main class="container my-10 w-115 mx-auto rounded-lg p-6 bg-white shadow-md">
        <h1 class="text-3xl font-bold text-center text-gray-700 mb-2">Create Your Account</h1>
        <hr class="mb-4 border-gray-300">
        <h3 class="text-xl mb-6 text-gray-700">Sign Up to Get Started</h3>

        <form action="/signup" method="POST">
          <!-- Showing Validation Errors -->
          <% if (errors.length > 0) { %>
            <div class="mb-4 bg-red-100 border border-red-300 text-red-500 px-4 py-3 rounded relative" role="alert">
              <strong class="font-bold">Error!</strong>
              <span class="block pl-2">
                <% errors.forEach(error => { %>
                  <li>
                    <%= error %>
                  </li>
                  <% }); %>
              </span>
              <span class="absolute top-0 bottom-0 right-0 px-4 py-3">
                <i class="fa-solid fa-xmark text-red-500 cursor-pointer" onclick="this.parentElement.parentElement.style.display='none'"></i>
              </span>
            </div>
            <% } %>

              <!-- Inputs Starts Here -->
              <div class="relative w-full flex gap-x-4">
                <!-- First Name -->
                <input
                  class="border border-gray-300 rounded-full py-3 pl-12 mb-4 w-full focus:outline-none focus:border-sky-500"
                  type="text" id="firstName" name="firstName" placeholder="First Name" value="<%= oldInput.firstName %>"
                  required>
                <div class="absolute inset-y-1 left-4 flex items-center pointer-events-none">
                  <i class="fa-regular fa-address-card text-gray-300 pb-4 text-xl"></i>
                </div>
                <!-- Last Name -->
                <input
                  class="border border-gray-300 rounded-full py-3 pl-12 mb-4 w-full focus:outline-none focus:border-sky-500"
                  type="text" id="lastName" name="lastName" placeholder="Last Name" value="<%= oldInput.lastName %>"
                  required>
                <div class="absolute inset-y-1 right-40 flex items-center pointer-events-none">
                  <i class="fa-regular fa-address-card text-gray-300 pb-4 text-xl"></i>
                </div>
              </div>

              <!-- Email -->
              <div class="relative w-full">
                <input
                  class="border border-gray-300 rounded-full py-3 pl-12 mb-4 w-full focus:outline-none focus:border-sky-500"
                  type="text" id="email" name="email" placeholder="Email Address" value="<%= oldInput.email %>"
                  required>
                <div class="absolute inset-y-1 left-4 flex items-center pointer-events-none">
                  <i class="fa-regular fa-envelope text-gray-300 pb-4 text-xl"></i>
                </div>
              </div>
              <!-- Password -->
              <div class="relative w-full">
                <input
                  class="border border-gray-300 rounded-full py-3 pl-12 mb-4 w-full focus:outline-none focus:border-sky-500"
                  type="password" id="password" name="password" placeholder="Password" required>
                <div class="absolute inset-y-0 left-4 flex items-center pointer-events-none">
                  <i class="fa-solid fa-lock text-gray-300 pb-4 text-xl"></i>
                </div>
              </div>
              <!-- Confirm Password -->
              <div class="relative w-full">
                <input
                  class="border border-gray-300 rounded-full py-3 pl-12 mb-4 w-full focus:outline-none focus:border-sky-500"
                  type="password" id="confirmPassword" name="confirmPassword" placeholder="Confirm Password" required>
                <div class="absolute inset-y-0 left-4 flex items-center pointer-events-none">
                  <i class="fa-solid fa-lock text-gray-300 pb-4 text-xl"></i>
                </div>
              </div>

              <!-- User Type -->
              <div class="mb-4 border border-gray-300 p-4 rounded-lg">
                <p class="text-black text-sm mb-2">I want to register as:</p>
                <div class="flex gap-4">
                  <label for="guest"><input id="guest" type="radio" name="userType" value="guest" class="mr-2"><span
                      class="font-medium cursor-pointer">Guest</span></label>
                  <label for="host"><input id="host" type="radio" name="userType" value="host" class="mr-2"><span
                      class="font-medium cursor-pointer">Host</span></label>
                </div>
              </div>

              <!-- Terms and Conditions -->
              <div class="mb-4">
                <label class="text-gray-700 text-sm" for="terms"><input type="checkbox" name="termsAccepted"
                    id="termsAccepted" class="cursor-pointer size-4" required> I agree to the
                  <a href="#" class="text-blue-500">Terms and Conditions</a></label>
              </div>

              <!-- Signup Button -->
              <input class="text-white bg-blue-500 py-3 px-4 mb-4 w-full rounded-full hover:bg-blue-600 cursor-pointer"
                type="submit" value="Register">

              <!-- Already have an account? Login -->
              <p class="text-center">Already have an account? <a href="/login"
                  class="text-blue-500 font-medium">Login</a></p>
        </form>
      </main>

  </body>

  </html>