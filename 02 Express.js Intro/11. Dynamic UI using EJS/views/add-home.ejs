<%- include('partials/head') %>
</head>

<body class="flex flex-wrap flex-col items-center">
  <%- include('partials/header') %>
  <header>
    <h1 class="text-white bg-black text-3xl p-4 font-medium shadow-lg rounded-lg mt-10">Add a New Home</h1>
  </header>

  <main class="mt-10 border p-6 rounded-lg shadow-lg w-1/4">
    <form action="/add-home" method="POST">
      <label class="" for="houseName">House Name:</label><br>
      <input class="border border-gray-300 rounded-sm lg:w-50 sm:w-30 max-sm:w-20" type="text" id="houseName" name="houseName"><br>
      <label for="locationName">Location:</label><br>
      <input class="border border-gray-300 rounded-sm lg:w-50 sm:w-30 max-sm:w-20" type="text" id="locationName" name="locationName"><br><br>
      <input class="text-white font-medium bg-sky-500 p-1 px-3 rounded-sm block mx-auto hover:bg-sky-600" type="submit" value="Submit">
    </form>
  </main>

</body>

</html>