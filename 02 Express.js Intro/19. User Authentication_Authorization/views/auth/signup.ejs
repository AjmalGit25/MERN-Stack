<%- include('../partials/head') %>

  <body class="bg-blue-500">
    <%- include('../partials/header') %>
      <main class="container my-10 w-115 mx-auto rounded-lg p-6 bg-white shadow-md">
        <h1 class="text-3xl font-bold text-center text-gray-700 mb-2">Register Your Account</h1>
        <hr class="mb-4 text-gray-300">
        <h3 class="text-xl mb-6 text-gray-700">Sign Up to Get Started</h3>

        <form action="/signup" method="POST">
          <!-- Error Message Box -->
          <% if (typeof errors !==undefined && errors.length> 0) { %>
            <div class="bg-red-100 border border-red-400 rounded-md p-4 mb-4 text-red-700">
              <strong>Error!</strong>
              <ul class="list-disc pl-5 mt-2">
                <% errors.forEach(error=> { %>
                  <li>
                    <%= error %>
                  </li>
                  <% }); %>
              </ul>
            </div>
            <% } %>

              <div class="flex gap-4 w-full">
                <!-- First Name  -->
                <div class="relative">
                  <input
                    class="border border-gray-300 rounded-full w-full py-3 pl-12 mb-4 focus:outline-none focus:border-sky-500"
                    type="text" id="firstName" name="firstName" placeholder="First Name"
                    value="<%= oldInput.firstName %>" required>
                  <div class="absolute inset-y-1 left-4 flex items-center pointer-events-none">
                    <i class="fa-solid fa-user text-gray-300 pb-4 text-xl"></i>
                  </div>
                </div>
                <!-- Last Name  -->
                <div class="relative">
                  <input
                    class="border border-gray-300 rounded-full w-full py-3 pl-12 mb-4 focus:outline-none focus:border-sky-500"
                    type="text" id="lastName" name="lastName" placeholder="Last Name" value="<%= oldInput.lastName %>">
                  <div class="absolute inset-y-1 left-4 flex items-center pointer-events-none">
                    <i class="fa-solid fa-user text-gray-300 pb-4 text-xl"></i>
                  </div>
                </div>
              </div>
              <!-- Email -->
              <div class="relative w-full">
                <input
                  class="border border-gray-300 rounded-full py-3 pl-12 mb-4 w-full focus:outline-none focus:border-sky-500"
                  type="text" id="email" name="email" placeholder="Email Address" value="<%= oldInput.email %>"
                  required>
                <div class="absolute inset-y-1 left-4 flex items-center pointer-events-none">
                  <i class="fa-regular fa-envelope text-gray-300 pb-4 text-xl"></i>
                </div>
              </div>
              <!-- Password -->
              <div class="relative w-full">
                <input
                  class="border border-gray-300 rounded-full py-3 pl-12 mb-4 w-full focus:outline-none focus:border-sky-500"
                  type="password" id="password" name="password" placeholder="Password" required>
                <div class="absolute inset-y-0 left-4 flex items-center pointer-events-none">
                  <i class="fa-solid fa-lock text-gray-300 pb-4 text-xl"></i>
                </div>
              </div>
              <!-- Confirm Password -->
              <div class="relative w-full">
                <input
                  class="border border-gray-300 rounded-full py-3 pl-12 mb-4 w-full focus:outline-none focus:border-sky-500"
                  type="password" id="confirmPassword" name="confirmPassword" placeholder="Confirm Password" required>
                <div class="absolute inset-y-0 left-4 flex items-center pointer-events-none">
                  <i class="fa-solid fa-lock text-gray-300 pb-4 text-xl"></i>
                </div>
              </div>
              <!-- User Type -->
              <div class="mb-4 border border-gray-300 rounded-md p-2">
                <p class="text-gray-600">User Type:</p>
                <div class="flex gap-6 mt-2 font-medium">
                  <label for="guest">
                    <input type="radio" id="guest" name="userType" value="guest" <%=oldInput.userType==='guest'
                      ? 'checked' : '' %>>
                    <span class="ml-2 text-gray-700">Guest</span>
                  </label>
                  <label for="admin">
                    <input type="radio" id="admin" name="userType" value="admin" <%=oldInput.userType==='admin'
                      ? 'checked' : '' %>>
                    <span class="ml-2 text-gray-700">Admin</span>
                  </label>
                </div>
              </div>
              <!-- Terms and Conditions -->
              <div class="mb-6">
                <input type="checkbox" id="terms" name="terms" value="accepted" required>
                <label for="terms" class="ml-2">I accept the <a href="#" class="text-blue-500">Terms and
                    Conditions</a></label>
              </div>

              <!-- Sign Up Button -->
              <input
                class="text-white bg-blue-500 font-medium py-3 px-4 mb-4 w-full rounded-full hover:bg-blue-600 cursor-pointer"
                type="submit" value="Sign Up">

              <!-- Login Link -->
              <p class="text-gray-600 text-center mt-2">Already have an account? <a href="/login"
                  class="text-blue-600 font-medium">Login</a></p>
        </form>
      </main>

  </body>

  </html>